VITE_API_URL=http://localhost:8000
# Web push (optional) — the public half of the VAPID keypair. Leave unset
# to skip push subscription entirely (in-app bell alerts still work).
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# Login gate (optional) — leave both unset to stay in single-operator
# file-mode (no login screen, current behavior). Set both to require
# email magic-link sign-in; identity only for now, data stays shared.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
